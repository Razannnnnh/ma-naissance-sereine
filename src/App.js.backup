        <span style={{ color: C.mauve, fontSize: 20, transform: open ? "rotate(45deg)" : "none", transition: "transform 0.3s", display: "block" }}>+</span>
      </div>
      {open && <div className="resource-body">{r.content}</div>}
    </div>
  );
}

